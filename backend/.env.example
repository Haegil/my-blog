# Server Config
PORT=5000
SESSION_SECRET=your-super-secret-session-key-change-this

# Oracle Database Config (Thin Mode)
ORACLE_USER=system
ORACLE_PASSWORD=your_oracle_password
# 예: localhost:1521/XEPDB1 또는 localhost:1521/xe
ORACLE_CONNECTION_STRING=localhost:1521/XEPDB1

# Default Admin Credentials (Auto-created if no user exists in database)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
