# Server Config
PORT=5000
SESSION_SECRET=your-super-secret-session-key-change-this

# PostgreSQL Database Config
# Supabase 또는 Local PostgreSQL 연결 문자열 (Connection String)
# 로컬 예시: postgresql://postgres:password@localhost:5432/my_blog
# Supabase 예시: postgresql://postgres.xxxxxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_blog

# 개별 설정 변수 (DATABASE_URL을 지정하지 않았을 때 사용되는 로컬용 폴백)
PGUSER=postgres
PGPASSWORD=postgres
PGHOST=localhost
PGDATABASE=my_blog
PGPORT=5432

# Default Admin Credentials (Auto-created if no user exists in database)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
